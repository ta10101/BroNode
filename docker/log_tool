#!/usr/bin/env bash

set -e
set -u

# Script version
VERSION="0.1.0"

# Configuration
LOG_SENDER_BIN="/usr/local/bin/log-sender"
CONFIG_FILE="/etc/log-sender/config.json"
ENDPOINT="https://log-collector.example.com"
UNYT_PUB_KEY="${LOG_SENDER_UNYT_PUB_KEY:-}"
REPORT_INTERVAL="${LOG_SENDER_REPORT_INTERVAL_SECONDS:-3600}"
LOG_PATH="/var/log"

# Logging setup
LOG_TAG="log_tool"
log() {
    logger -t "$LOG_TAG" "$1"
}

# Usage help
usage() {
    cat << EOF
Usage: $0 [command] [options]

Commands:
  init      Initialize configuration
  service   Run log collection service
  help      Show this help

For command-specific help: $0 <command> --help
EOF
    exit 1
}

# Initialize command
init_command() {
    # Initialize variables with defaults
    local endpoint_val="${LOG_SENDER_ENDPOINT:-$ENDPOINT}"
    local pub_key_val="${LOG_SENDER_UNYT_PUB_KEY:-$UNYT_PUB_KEY}"
    local interval_val="${LOG_SENDER_REPORT_INTERVAL_SECONDS:-$REPORT_INTERVAL}"

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --endpoint)
                endpoint_val="$2"
                shift 2
                ;;
            --unyt-pub-key)
                pub_key_val="$2"
                shift 2
                ;;
            --report-interval-seconds)
                interval_val="$2"
                shift 2
                ;;
            *)
                echo "Unknown argument: $1"
                exit 1
                ;;
        esac
    done

    # Build the command
    local CMD=("$LOG_SENDER_BIN" init)
    CMD+=(--config-file "$CONFIG_FILE")
    CMD+=(--endpoint "$endpoint_val")
    
    if [ -n "$pub_key_val" ]; then
        CMD+=(--unyt-pub-key "$pub_key_val")
    else
        log "Error: UNYT public key required for init (set via UNYT_PUB_KEY or LOG_SENDER_UNYT_PUB_KEY or --unyt-pub-key argument)"
        exit 1
    fi
    
    CMD+=(--report-interval-seconds "$interval_val")
    
    # Execute the command
    "${CMD[@]}"
}

# Service command
service_command() {
    if [ ! -f "$CONFIG_FILE" ]; then
        log "Error: Config file not found: $CONFIG_FILE"
        exit 1
    fi
    
    # Use LOG_SENDER_LOG_PATH if set, otherwise default to LOG_PATH
    local REPORT_PATH="${LOG_SENDER_LOG_PATH:-$LOG_PATH}"
    
    "$LOG_SENDER_BIN" service \
        --config-file "$CONFIG_FILE" \
        --report-path "$REPORT_PATH"
}

# Main execution
case "$1" in
    init)
        shift
        init_command "$@"
        ;;
    service)
        shift
        service_command "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        log "Unknown command: $1"
        usage
        ;;
esac
