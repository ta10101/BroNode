#!/usr/bin/env bash
set -euo pipefail

# Function to validate APP_ID format
validate_app_id() {
  local app_id="$1"
  if ! [[ "$app_id" =~ ^[a-zA-Z0-9_:\.-]+$ ]] && ! [[ "$app_id" =~ ^[a-zA-Z0-9_:\.-]+(\:\:[a-zA-Z0-9_:\.-]+)*$ ]]; then
    echo "[!] Invalid APP_ID format: $app_id" >&2
    exit 1
  fi
}

# Function to validate port number
validate_port() {
  local port="$1"
  if ! [[ "$port" =~ ^[0-9]+$ ]] || [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
    echo "[!] Invalid port number: $port" >&2
    exit 1
  fi
}

# Function to extract DNA hash from installed app
# Supports both HC 0.5.6 (regex-based) and HC 0.6.0+ (JSON) output formats
# Arguments: $1 = admin_port, $2 = app_id
# Returns: DNA hash via stdout, empty if not found
extract_dna_hash() {
  local admin_port="$1"
  local app_id="$2"
  local list_apps_output dna_hash
  
  list_apps_output=$(hc s call -r "$admin_port" list-apps 2>/dev/null || true)
  
  # Try JSON parsing first (HC 0.6.0+ returns JSON)
  dna_hash=$(echo "$list_apps_output" | grep -v "Initialising" | \
    jq -r --arg app_id "$app_id" '.[] | select(.installed_app_id == $app_id) | .cell_info | to_entries[0].value[0].value.cell_id.dna_hash' 2>/dev/null || true)
  
  # If JSON parsing failed, try regex parsing (HC 0.5.6 returns "AppInfo {" format)
  if [ -z "$dna_hash" ]; then
    dna_hash=$(echo "$list_apps_output" | sed 's/AppInfo {/\n&/g' | grep "installed_app_id: \"$app_id\"" | awk -F 'DnaHash\\(|\\), AgentPubKey' '{print $2}' || true)
  fi
  
  echo "$dna_hash"
}

SCRIPT_NAME=$(basename "$0")

# --- Usage ---
usage() {
  cat <<EOF
Usage: happ_tool <command> [-p <admin_port>] [args...]

Commands:
  install <config.json> [node_name]   Install a hApp from a config file
  uninstall <app_id>                  Uninstall a hApp
  enable <app_id>                     Enable an installed hApp
  disable <app_id>                    Disable an installed hApp
  list                                List installed hApps

Options:
  -p <port>    Admin port (default: 4444)
  --help, -h   Show this help
EOF
}

# --- Argument Parsing ---
# This script uses `getopts` to parse flags.
# The -p flag is used to specify the admin port.
# If -p is not provided, it defaults to 4444.
ADMIN_PORT="4444"
while getopts ":p:" opt; do
  case ${opt} in
    p )
      ADMIN_PORT=$OPTARG
      ;;
    \? )
      echo "Invalid option: -$OPTARG" >&2
      exit 1
      ;;
    : )
      echo "Invalid option: -$OPTARG requires an argument" >&2
      exit 1
      ;;
  esac
done
shift $((OPTIND -1))
validate_port "$ADMIN_PORT"

# --- Subcommand dispatch (when called directly as happ_tool) ---
if [ "$SCRIPT_NAME" = "happ_tool" ]; then
  COMMAND="${1:-help}"
  shift 2>/dev/null || true
  case "$COMMAND" in
    install)
      # Fall through to main install logic below
      ;;
    uninstall)
      APP_ID="${1:-}"
      if [ -z "$APP_ID" ]; then
        echo "Usage: happ_tool uninstall [-p <admin_port>] <app_id>"
        exit 1
      fi
      validate_app_id "$APP_ID"
      echo "[*] Uninstalling app $APP_ID..."
      hc s call -r "$ADMIN_PORT" uninstall-app "$APP_ID"
      echo "[✔] App $APP_ID uninstalled!"
      exit 0
      ;;
    enable)
      APP_ID="${1:-}"
      if [ -z "$APP_ID" ]; then
        echo "Usage: happ_tool enable [-p <admin_port>] <app_id>"
        exit 1
      fi
      validate_app_id "$APP_ID"
      echo "[*] Enabling app $APP_ID..."
      hc s call -r "$ADMIN_PORT" enable-app "$APP_ID"
      echo "[✔] App $APP_ID enabled!"
      exit 0
      ;;
    disable)
      APP_ID="${1:-}"
      if [ -z "$APP_ID" ]; then
        echo "Usage: happ_tool disable [-p <admin_port>] <app_id>"
        exit 1
      fi
      validate_app_id "$APP_ID"
      echo "[*] Disabling app $APP_ID..."
      hc s call -r "$ADMIN_PORT" disable-app "$APP_ID"
      echo "[✔] App $APP_ID disabled!"
      exit 0
      ;;
    list)
      hc s call -r "$ADMIN_PORT" list-apps
      exit 0
      ;;
    help|--help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown command: $COMMAND"
      usage
      exit 1
      ;;
  esac
fi

# --- Legacy sub-commands (via symlinks, for backward compatibility) ---
# The script behaves differently based on the name it's called with.
if [ "$SCRIPT_NAME" = "list_happs" ]; then
  hc s call -r "$ADMIN_PORT" list-apps
  exit 0
fi

if [ "$SCRIPT_NAME" = "uninstall_happ" ]; then
  APP_ID="$1"
  if [ -z "$APP_ID" ]; then
    echo "Usage: uninstall_happ [-p <ADMIN_PORT>] <APP_ID>"
    exit 1
  fi
  validate_app_id "$APP_ID"
  echo "[*] Uninstalling app $APP_ID..."
  hc s call -r "$ADMIN_PORT" uninstall-app "$APP_ID"
  echo "[✔] App $APP_ID uninstalled!"
  exit 0
fi

if [ "$SCRIPT_NAME" = "enable_happ" ]; then
  APP_ID="$1"
  if [ -z "$APP_ID" ]; then
    echo "Usage: enable_happ [-p <ADMIN_PORT>] <APP_ID>"
    exit 1
  fi
  validate_app_id "$APP_ID"
  echo "[*] Enabling app $APP_ID..."
  hc s call -r "$ADMIN_PORT" enable-app "$APP_ID"
  echo "[✔] App $APP_ID enabled!"
  exit 0
fi

if [ "$SCRIPT_NAME" = "disable_happ" ]; then
  APP_ID="$1"
  if [ -z "$APP_ID" ]; then
    echo "Usage: disable_happ [-p <ADMIN_PORT>] <APP_ID>"
    exit 1
  fi
  validate_app_id "$APP_ID"
  echo "[*] Disabling app $APP_ID..."
  hc s call -r "$ADMIN_PORT" disable-app "$APP_ID"
  echo "[✔] App $APP_ID disabled!"
  exit 0
fi

# Handle --help flag for any command
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

# --- Main script: install_happ ---
# This is the default command when the script is not called as one of the sub-commands.
CONFIG_FILE="$1"
if [ -z "$CONFIG_FILE" ] || [ ! -f "$CONFIG_FILE" ]; then
  echo "Usage: install_happ [-p <ADMIN_PORT>] <CONFIG_FILE> [<NODE_NAME>]"
  exit 1
fi

NODE_NAME="${2:-$(hostname)}"

echo "DEBUG: Starting JSON parsing"

# ---- Parse JSON ----
APP_NAME=$(jq -r '.app.name' "$CONFIG_FILE")
APP_VERSION=$(jq -r '.app.version // "0.0.1"' "$CONFIG_FILE")
HAPP_URL=$(jq -r '.app.happUrl' "$CONFIG_FILE")
HAPP_SHA256=$(jq -r '.app.happSha256 // empty' "$CONFIG_FILE")
NETWORK_SEED=$(jq -r '.app.modifiers.networkSeed // empty' "$CONFIG_FILE")
if [ -z "$NETWORK_SEED" ]; then
  echo "[*] No network seed provided, generating a random one for testing..."
  if command -v uuidgen &> /dev/null; then
    NETWORK_SEED=$(uuidgen)
    echo "[*] Generated network seed: $NETWORK_SEED"
  else
    echo "[!] uuidgen command not found. Please install it to generate a network seed."
    exit 1
  fi
fi

# ---- Download and verify happ file ----
# Determine file extension from URL
DOWNLOADED_FILE="/var/local/lib/holochain/tmp/${APP_NAME}-${APP_VERSION}"
if [[ "$HAPP_URL" == *.webhapp ]]; then
  DOWNLOADED_FILE="${DOWNLOADED_FILE}.webhapp"
  HAPP_FILE="/var/local/lib/holochain/tmp/${APP_NAME}-${APP_VERSION}.happ"
else
  DOWNLOADED_FILE="${DOWNLOADED_FILE}.happ"
  HAPP_FILE="$DOWNLOADED_FILE"
fi

echo "DEBUG: Starting happ download"
echo "[*] Downloading happ from $HAPP_URL ..."
if ! curl -sSfL "$HAPP_URL" -o "$DOWNLOADED_FILE"; then
  echo "[!] Failed to download happ from $HAPP_URL" >&2
  exit 1
fi

if [ ! -s "$DOWNLOADED_FILE" ]; then
  echo "[!] Downloaded file is empty" >&2
  rm -f "$DOWNLOADED_FILE"
  exit 1
fi

# Check if we need to extract .happ from .webhapp
if [[ "$HAPP_URL" == *.webhapp ]]; then
  echo "[*] Detected .webhapp file, extracting .happ file..."
  EXTRACT_DIR=$(mktemp -d -u)
  
  if ! hc web-app unpack "$DOWNLOADED_FILE" -o "$EXTRACT_DIR"; then
    echo "[!] Failed to extract .happ file from .webhapp" >&2
    rm -f "$DOWNLOADED_FILE"
    rm -rf "$EXTRACT_DIR"
    exit 1
  fi
  
  # Find the extracted .happ file
  EXTRACTED_HAPP=$(find "$EXTRACT_DIR" -name "*.happ" -type f | head -n 1)
  if [ -z "$EXTRACTED_HAPP" ] || [ ! -f "$EXTRACTED_HAPP" ]; then
    echo "[!] No .happ file found in .webhapp" >&2
    rm -f "$DOWNLOADED_FILE"
    rm -rf "$EXTRACT_DIR"
    exit 1
  fi
  
  # Move the extracted .happ file to our expected location
  if ! mv "$EXTRACTED_HAPP" "$HAPP_FILE"; then
    echo "[!] Failed to move extracted .happ file to $HAPP_FILE" >&2
    rm -f "$DOWNLOADED_FILE"
    rm -rf "$EXTRACT_DIR"
    exit 1
  fi
  
  # Clean up extraction directory
  rm -rf "$EXTRACT_DIR"
  echo "[✔] Successfully extracted .happ file from .webhapp"
fi
 
if [ -n "$HAPP_SHA256" ]; then
  echo "[*] Verifying SHA256 checksum..."
  DOWNLOAD_SHA256=$(sha256sum "$HAPP_FILE" | awk '{print $1}')
  if [ "$DOWNLOAD_SHA256" != "$HAPP_SHA256" ]; then
    echo "[!] Checksum mismatch!"
    echo "    Expected: $HAPP_SHA256"
    echo "    Actual:   $DOWNLOAD_SHA256"
    rm -f "$DOWNLOADED_FILE" "$HAPP_FILE"
    exit 1
  fi
  echo "[✔] Checksum verified."
fi

# ---- Generate agent key ----
echo "DEBUG: Starting agent key generation"
RAW_OUTPUT=$(hc s call -r "$ADMIN_PORT" new-agent 2>&1)
echo "[*] Debug: Raw new-agent output:"
echo "$RAW_OUTPUT"

# Robust agent key extraction with fallback strategies
# Try multiple extraction methods to handle different Holochain versions

# Method 1: Original simple extraction (for hc-0.5.6 and standard images)
AGENT_KEY=$(echo "$RAW_OUTPUT" | awk '{print $NF}' | tr -d '"' | grep -v '^$')

# Method 2: JSON format extraction (for UNYT images with reporting)
if [ -z "$AGENT_KEY" ] || ! [[ "$AGENT_KEY" =~ ^[A-Za-z0-9_-]{30,}$ ]]; then
    echo "[*] Method 1 failed, trying JSON extraction..."
    AGENT_KEY=$(echo "$RAW_OUTPUT" | \
      grep -E '"[A-Za-z0-9_-]{40,}"' | \
      sed 's/.*"\([A-Za-z0-9_-]\{40,\}\)".*/\1/' | \
      head -1)
fi

# Method 3: Fallback - extract anything that looks like a key
if [ -z "$AGENT_KEY" ] || ! [[ "$AGENT_KEY" =~ ^[A-Za-z0-9_-]+$ ]]; then
    echo "[*] Method 2 failed, trying fallback extraction..."
    AGENT_KEY=$(echo "$RAW_OUTPUT" | \
      grep -o -E '[A-Za-z0-9_-]{30,}' | \
      grep -v 'Log\|Initialising' | \
      head -1)
fi

# Final validation
if [ -z "$AGENT_KEY" ]; then
    echo "[!] Failed to extract agent key from output" >&2
    echo "[!] All extraction methods failed" >&2
    echo "[!] Raw output was:" >&2
    echo "$RAW_OUTPUT" >&2
    exit 1
fi

if ! [[ "$AGENT_KEY" =~ ^[A-Za-z0-9_-]{30,}$ ]]; then
    echo "[!] Extracted key '$AGENT_KEY' doesn't look valid" >&2
    echo "[!] Raw output was:" >&2
    echo "$RAW_OUTPUT" >&2
    exit 1
fi

echo "[*] Generated agent key: $AGENT_KEY"

# ---- Build App ID ----
echo "DEBUG: Starting App ID build"
APP_ID="${APP_NAME}::${APP_VERSION}::${AGENT_KEY}"
echo "[*] App ID = $APP_ID"
validate_app_id "$APP_ID"

# ---- Install app ----
echo "DEBUG: Preparing to install app"
echo "[*] Installing app..."
hc s call -r "$ADMIN_PORT" install-app \
  --agent-key "$AGENT_KEY" \
  --app-id "$APP_ID" \
  "$HAPP_FILE" \
  "$NETWORK_SEED"

# ---- Enable app ----
echo "DEBUG: App install command finished, preparing to enable"
echo "[*] Enabling app..."
hc s call -r "$ADMIN_PORT" enable-app "$APP_ID"

# ---- Initial zome calls (if configured) ----
INIT_CALLS_JSON=$(jq -c '.app.initZomeCalls // .app.init_zome_calls // []' "$CONFIG_FILE")
if [ "$INIT_CALLS_JSON" != "[]" ]; then
  echo "[*] Found initZomeCalls in config; authorizing zome calls..."
  echo "" | hc s zome-call-auth --piped -r "$ADMIN_PORT" "$APP_ID"
  
  echo "[*] Getting app info to extract DnaHash for $APP_ID..."
  DNA_HASH=$(extract_dna_hash "$ADMIN_PORT" "$APP_ID")

  if [ -n "$DNA_HASH" ]; then
    echo "[*] Extracted DnaHash: $DNA_HASH"
    echo "[*] Iterating init zome calls..."
    jq -c '.app.initZomeCalls[] // .app.init_zome_calls[]' "$CONFIG_FILE" | while read -r call; do
      ZOME=$(printf '%s' "$call" | jq -r '.zome')
      FN_NAME=$(printf '%s' "$call" | jq -r '.fn_name')
      PAYLOAD=$(printf '%s' "$call" | jq -c '.payload')
      
      if echo "$PAYLOAD" | grep -q "<NODE_NAME>"; then
        if [ "$NODE_NAME" = "$(hostname)" ] && [ -z "${2:-}" ]; then
          echo "[!] Error: PAYLOAD contains <NODE_NAME> placeholder but NODE_NAME parameter was not provided"
          echo "[!] Usage: install_happ [-p <ADMIN_PORT>] <CONFIG_FILE> <NODE_NAME>"
          exit 1
        fi
        PAYLOAD=$(echo "$PAYLOAD" | sed "s/<NODE_NAME>/$NODE_NAME/g")
      fi
      
      echo "calling $FN_NAME with $PAYLOAD"
      echo "" | hc s zome-call --piped -r "$ADMIN_PORT" "$APP_ID" "$DNA_HASH" "$ZOME" "$FN_NAME" "$PAYLOAD"
    done
  else
    echo "[!] Could not extract DnaHash from apps list"
  fi
fi

# ---- Extract DNA_HASH if not already done (needed for register-dna) ----
if [ -z "${DNA_HASH:-}" ]; then
  echo "[*] Getting app info to extract DnaHash for $APP_ID..."
  DNA_HASH=$(extract_dna_hash "$ADMIN_PORT" "$APP_ID")
  if [ -n "$DNA_HASH" ]; then
    echo "[*] Extracted DnaHash: $DNA_HASH"
  else
    echo "[!] Could not extract DnaHash from apps list"
  fi
fi

# ---- Log-sender initialization and DNA registration ----
# Check if happ has economics section with agreementHash
AGREEMENT_ID=$(jq -r '.economics.agreementHash // empty' "$CONFIG_FILE")
PRICE_SHEET_HASH=$(jq -r '.economics.priceSheetHash // empty' "$CONFIG_FILE")

if [ -n "$AGREEMENT_ID" ]; then
  CONFIG_PATH="/etc/log-sender/config.json"
  
  # Step 1: Initialize log-sender if not already done
  if [ ! -f "$CONFIG_PATH" ]; then
    echo "[*] Log-sender not initialized, checking environment..."
    
    # Required env vars for log-sender init
    ENDPOINT="${LOG_SENDER_ENDPOINT:-}"
    UNYT_KEY="${LOG_SENDER_UNYT_PUB_KEY:-}"
    INTERVAL="${LOG_SENDER_REPORT_INTERVAL_SECONDS:-60}"
    REPORT_PATH="${LOG_SENDER_LOG_PATH:-/var/local/lib/holochain/reports/}"
    CONDUCTOR_CONFIG="/etc/holochain/conductor-config.yaml"
    
    if [ -z "$ENDPOINT" ] || [ -z "$UNYT_KEY" ]; then
      echo "[!] LOG_SENDER_ENDPOINT and LOG_SENDER_UNYT_PUB_KEY required for init"
      echo "[!] Skipping log-sender initialization"
    else
      echo "[*] Initializing log-sender..."
      echo "[*]   Endpoint: $ENDPOINT"
      echo "[*]   UNYT Pub Key: $UNYT_KEY"
      echo "[*]   Report Interval: ${INTERVAL}s"
      echo "[*]   Report Path: $REPORT_PATH"
      
      log-sender init \
        --config-file "$CONFIG_PATH" \
        --endpoint "$ENDPOINT" \
        --unyt-pub-key "$UNYT_KEY" \
        --report-interval-seconds "$INTERVAL" \
        --report-path "$REPORT_PATH" \
        --conductor-config-path "$CONDUCTOR_CONFIG"
      
      echo "[✔] Log-sender initialized and drone registered with log-collector"
    fi
  else
    echo "[*] Log-sender already initialized"
  fi
  
  # Step 2: Register DNA with log-sender (if config exists)
  if [ -f "$CONFIG_PATH" ]; then
    echo "[*] Registering DNA with log-sender..."
    echo "[*]   DNA Hash: $DNA_HASH"
    echo "[*]   Agreement ID: $AGREEMENT_ID"
    
    # Build the command with required args
    REGISTER_CMD="log-sender register-dna --config-file $CONFIG_PATH --dna-hash \"$DNA_HASH\" --agreement-id \"$AGREEMENT_ID\""
    
    # Add optional price-sheet-hash if provided
    if [ -n "$PRICE_SHEET_HASH" ]; then
      echo "[*]   Price Sheet Hash: $PRICE_SHEET_HASH"
      REGISTER_CMD="$REGISTER_CMD --price-sheet-hash \"$PRICE_SHEET_HASH\""
    fi
    
    # Execute the registration
    eval $REGISTER_CMD
    echo "[✔] DNA registered with log-sender"
    
    # Step 3: Start log-sender service if not already running
    if ! pgrep -f "log-sender service" > /dev/null 2>&1; then
      echo "[*] Starting log-sender service..."
      nohup log-sender service --config-file "$CONFIG_PATH" \
        >> /data/logs/log-sender.log 2>&1 &
      echo "[✔] Log-sender service started (PID: $!)"
    else
      echo "[*] Log-sender service already running"
    fi
  fi
else
  echo "[*] No economics.agreementHash in config, skipping log-sender setup"
fi

echo "[✔] App $APP_NAME ($APP_ID) installed and enabled!"