<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 3.11+ : candle BroNode.wxs -dBroNodeExe=...\BroNode.exe && light BroNode.wixobj -o BroNodeSetup.msi
  Uninstall: Settings → Apps → BroNode → Uninstall (or Apps & Features)
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="BroNode"
      Language="1033"
      Version="1.0.0.0"
      Manufacturer="BroNode"
      UpgradeCode="E7F3F4B2-1A89-4C3F-9D2E-8B1C4A5E6F70">
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of BroNode is already installed." />
    <MediaTemplate />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="BroNode">
          <Component Id="MainExe" Guid="*">
            <File Id="BroNodeExe" Name="BroNode.exe" Source="$(var.BroNodeExe)" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="ProductFeature" Title="BroNode" Level="1">
      <ComponentRef Id="MainExe" />
    </Feature>

    <!-- Guided installer: welcome, install folder (default is fine), confirm, progress bar, finish -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <UIRef Id="WixUI_InstallDir" />
  </Product>
</Wix>
